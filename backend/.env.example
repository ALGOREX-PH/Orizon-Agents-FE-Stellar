# ─────────────────────────────────────────────────────────────
# Orizon Agents — Backend env (FastAPI + Agno + OpenAI + Stellar)
# ─────────────────────────────────────────────────────────────
# Copy to `.env` and fill OPENAI_API_KEY. Everything else has
# sensible defaults for local dev.

# ── OpenAI (required) ─────────────────────────────────────────
OPENAI_API_KEY=sk-...
ORCHESTRATOR_MODEL=gpt-5.3-codex
WORKER_MODEL=gpt-5.3-codex

# ── HTTP server ──────────────────────────────────────────────
# Comma-separated. In prod, set to your Vercel URL.
CORS_ORIGINS=http://localhost:3000
# Render/Fly/Cloud Run inject $PORT at runtime. Leave 8000 for local.
PORT=8000

# ── Stellar (testnet) ────────────────────────────────────────
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Public contract IDs from the testnet deploy (safe to commit).
STELLAR_AGENT_REGISTRY=CC5H4S4XAFV2TINHCNLFTLQYSZPN2GTJYJRQB64YJ42ZNISRWCUPS55B
STELLAR_REPUTATION_LEDGER=CCBWR7CS222YTIQPDH53JFRJLPIRRCT5MER7ASDUODA54XI5V2C4WRJT
STELLAR_PAYMENT_ESCROW=CC5I652QZYLPR72EATFLKPABESZAPSTJ2V4SBOSTCGLXKNNLOCDWTPX2
STELLAR_ATTESTATION_REGISTRY=CBSFGI4Z4YJX5ZRCRWDSYDDORBSSN7QT7AYK5QTDN27ES6SFBY7YIOVB
STELLAR_ASSET_SAC=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC

# Backend's signing identity. In prod, set STELLAR_SIGNING_KEY
# (S... secret) via host secrets — NEVER commit.
STELLAR_ADMIN_ADDRESS=GCO4EYZFPFKAXDFQFNG3MVCCK6VEJ2XYODYZCNKSJOWHG6PEDWLAKVGY
STELLAR_SIGNING_KEY=
